graph TD
%% Global Styles
classDef startEnd fill:#6366f1,stroke:#312e81,stroke-width:2px,color:#fff;
classDef process fill:#fff,stroke:#333,stroke-width:1px;
classDef decision fill:#faf5ff,stroke:#7e22ce,stroke-width:2px;
classDef database fill:#f0f9ff,stroke:#0369a1,stroke-width:1px;

Start((Mulai)) --> AuthDecision{Sudah Punya Akun?}

%% Alur Registrasi & Login
AuthDecision -- Belum --> RegPage[Halaman Registrasi]
RegPage --> RegSubmit[Input Data Toko & Admin]
RegSubmit --> DbSave{Simpan ke Supabase}
DbSave -- Sukses --> LoginPage[Halaman Login]

AuthDecision -- Sudah --> LoginPage
LoginPage --> LoginSubmit[Input Email & Password]
LoginSubmit --> AuthProcess{Verifikasi Supabase}

%% Alur Dashboard POS
AuthProcess -- Valid --> Dashboard[Dashboard POS Furniture]
AuthProcess -- Gagal --> LoginPage

Dashboard --> SelectProduct[Pilih Produk Furniture]
SelectProduct --> CartProcess[Update Keranjang Belanja]

%% Detail Aksi Transaksi
CartProcess --> CustomAction{Aksi Tambahan?}
CustomAction -- Diskon --> ApplyDisc[Input % Diskon]
CustomAction -- Qty --> UpdateQty[Update Jumlah Barang]
CustomAction -- Catatan --> AddNote[Input Customer Note]

ApplyDisc --> TotalCalc
UpdateQty --> TotalCalc
AddNote --> TotalCalc
CustomAction -- Tidak --> TotalCalc[Kalkulasi Total + Pajak]

%% Alur Pembayaran yang Diperluas
TotalCalc --> PaymentClick[Klik Tombol Payment]
PaymentClick --> PaymentMethod{Pilih Metode Bayar}

PaymentMethod -- Tunai --> CashProcess[Terima Uang Tunai]
PaymentMethod -- QRIS/E-Wallet --> QRProcess[Scan QR Code & Cek Status]
PaymentMethod -- Kartu Kredit/Debit --> CardProcess[Input Detail / Tap Mesin EDC]

CashProcess --> Validation{Uang Cukup?}
Validation -- Tidak --> CashProcess
Validation -- Ya --> ChangeCalc[Hitung Kembalian]

QRProcess --> PaySuccess{Pembayaran Berhasil?}
CardProcess --> PaySuccess

PaySuccess -- Gagal --> PaymentMethod
PaySuccess -- Sukses --> ChangeCalc

%% Finalisasi Data
ChangeCalc --> FinalDbUpdate[(Update Stok & Sales di Supabase)]
FinalDbUpdate --> PrintReceipt[Cetak Struk & Simpan PDF]
PrintReceipt --> NextOrder{Pesanan Baru?}

NextOrder -- Ya --> Dashboard
NextOrder -- Tidak --> End((Selesai/Logout))

%% Assigning Classes
class Start,End startEnd;
class AuthDecision,AuthProcess,DbSave,CustomAction,PaymentMethod,NextOrder,Validation,PaySuccess decision;
class FinalDbUpdate database;